# PostgreSQL (server/db.js — alohida maydonlar)
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=keldi
DATABASE_HOST=localhost
DATABASE_PORT=5432

# API (min 16 chars in production)
JWT_SECRET=change_me_min_16_chars__
JWT_EXPIRES=7d

PORT=8000

# Nginx/orqali HTTPS: X-Forwarded-* ishonchli bo‘lsa (Hikvision → https://domen/api/hikvision/event)
# TRUST_PROXY=1

# Production: ruxsat etilgan frontend domen(lar)i (vergul bilan); bo‘sh bo‘lsa barcha origin
# CORS_ORIGIN=https://myapp.example.com,https://www.example.com

# Bitta domen orqali SPA+API (vite build dan keyin dist mavjud bo‘lsa server index.html ni ham beradi)

# Hikvision HTTP monitoring: qurilmada URL https://SIZNING_DOMEN/api/hikvision/event (443, HTTPS). Ichki 8000 ni ochmang.
# POST /api/hikvision/event. Bo‘sh bo‘lsa tekshiruv yo‘q.
# HIKVISION_HTTP_SECRET=...
# WEBHOOK_ALLOWED_IPS — qurilmaning INTERNETdan chiqish IP si (bir nechta bo‘lsa vergul bilan).
# X-Forwarded-For birinchi qator tekshiriladi; 403 bo‘lsa IP ro‘yxatini yangilang yoki vaqtincha o‘chiring.
# WEBHOOK_ALLOWED_IPS=198.163.193.179,84.54.73.7
# Daqiqada bitta ulanish IP si uchun maksimal so‘rov; 0 yoki olib tashlanaganda cheklov yo‘q.
# WEBHOOK_MAX_PER_MINUTE=600
